# Telegram Bot Configuration
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID чата или группы для получения заявок
# Для получения ID группы добавьте бота в группу и отправьте сообщение
# Затем перейдите по ссылке: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here
